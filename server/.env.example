# Server-only development example.
# Docker deployments should use the root .env.example instead.

# Backend HTTP/API port.
PORT=3101

# Public URL of this Teable Sync service.
# Used by OAuth callbacks, browser redirects, and alert webhook payloads.
SERVER_PUBLIC_URL=http://localhost:3101

# Frontend URL users open in the browser.
# Usually the same as SERVER_PUBLIC_URL in production.
FRONTEND_BASE_URL=http://localhost:3101

# Teable instance URL.
# Required for Teable OAuth login and OAuth-based Teable connections.
TEABLE_OAUTH_HOST=http://localhost:3000

# Optional Teable OAuth login credentials.
# Leave empty if you only use token-based Teable connections.
TEABLE_OAUTH_CLIENT_ID=
TEABLE_OAUTH_CLIENT_SECRET=

# JWT signing secret for user login sessions.
# Must be changed outside throwaway local development.
JWT_SECRET=change-me-to-a-random-secret-in-production

# Encryption key for saved database passwords, Teable tokens, OAuth secrets, and alert webhook URL.
# Must stay stable after secrets are saved.
CONFIG_ENCRYPTION_KEY=change-me-to-a-random-secret-in-production

# Whether enabled scheduled/realtime tasks should be restored after restart.
AUTO_RESUME_TASKS=true

# Whether restored tasks should run immediately after restart.
AUTO_RESUME_RUN_IMMEDIATELY=false

# Delay between Teable API write requests in milliseconds.
TEABLE_RATE_LIMIT_MS=120

# Default hard guard for first full sync row estimate.
INITIAL_FULL_SYNC_MAX_ROWS=100000

# Default warning threshold for first full sync row estimate.
INITIAL_FULL_SYNC_WARN_ROWS=50000

# How often the backend scans active alerts and sends webhook notifications, in milliseconds.
# The server enforces a minimum of 15000ms.
ALERT_NOTIFICATION_SCAN_INTERVAL_MS=60000

# Business timezone for date-only reconciliation.
RECONCILE_DATE_TIME_ZONE=Asia/Shanghai
