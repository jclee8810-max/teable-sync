# ============================================================
# TeableSync 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# --- 服务端口 ---
PORT=3100                    # 后端 API 端口

# --- 服务器公网地址（OAuth 回调用）---
# 开发环境：http://localhost:3100
# 生产环境：https://sync.yourcompany.com（不要加尾部斜杠）
SERVER_PUBLIC_URL=http://localhost:3100

# --- 前端地址（用于 OAuth 回调重定向）---
# 开发环境：通常与后端端口不同
# 生产环境：填入实际的公网访问地址
FRONTEND_BASE_URL=http://localhost:5174

# --- Teable 实例地址 ---
# 自托管：http://localhost:3000 或 http://your-server:3000
# 云版本：https://app.teable.ai
TEABLE_OAUTH_HOST=http://localhost:3000

# --- Teable OAuth 应用凭证 ---
# 请在 Teable 管理后台 → 设置 → OAuth 应用 创建后填入
TEABLE_OAUTH_CLIENT_ID=
TEABLE_OAUTH_CLIENT_SECRET=

# --- JWT 密钥 ---
# 生产环境务必修改为强随机字符串（32字节以上）
JWT_SECRET=teable-sync-dev-secret-change-in-production

# --- 自动恢复定时任务 ---
# 设置为 true 则服务重启时自动恢复所有启用的定时同步任务
AUTO_RESUME_TASKS=false

# --- 数据库连接示例（仅供参考，业务逻辑中连接由用户通过界面配置）---
# MSSQL_HOST=localhost
# MSSQL_PORT=1433
# MSSQL_USER=sa
# MSSQL_PASSWORD=YourStrongPassword

# ============================================================
# Docker 部署示例
# ============================================================
# docker run -d -p 3100:3100 \
#   -e PORT=3100 \
#   -e SERVER_PUBLIC_URL=https://sync.yourcompany.com \
#   -e FRONTEND_BASE_URL=https://sync.yourcompany.com \
#   -e TEABLE_OAUTH_HOST=http://your-teable:3000 \
#   -e TEABLE_OAUTH_CLIENT_ID=your-client-id \
#   -e TEABLE_OAUTH_CLIENT_SECRET=your-client-secret \
#   -e JWT_SECRET=your-random-secret \
#   --name teable-sync \
#   teable-sync:latest