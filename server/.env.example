# Server-only development example.
# Docker deployments should use the root .env.example instead.

PORT=3101

# Public URLs used by OAuth and browser redirects.
SERVER_PUBLIC_URL=http://localhost:3101
FRONTEND_BASE_URL=http://localhost:3101
TEABLE_OAUTH_HOST=http://localhost:3000

# Optional Teable OAuth login credentials.
TEABLE_OAUTH_CLIENT_ID=
TEABLE_OAUTH_CLIENT_SECRET=

# Required outside throwaway development.
JWT_SECRET=change-me-to-a-random-secret-in-production
CONFIG_ENCRYPTION_KEY=change-me-to-a-random-secret-in-production

# Scheduler behavior after restart.
AUTO_RESUME_TASKS=true
AUTO_RESUME_RUN_IMMEDIATELY=false

# Teable API pacing and reconciliation date handling.
TEABLE_RATE_LIMIT_MS=120
RECONCILE_DATE_TIME_ZONE=Asia/Shanghai
