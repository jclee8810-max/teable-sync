{
  "name": "teable-sync",
  "version": "1.0.0",
  "description": "SQL → Teable 数据同步工具 | v1.0.0 (2026-04-27 Docker部署支持)",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && node --watch src/index.js",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "cd server && node src/index.js",
    "test:reliability": "node server/scripts/sync-engine-self-test.mjs",
    "test:ui-state": "node client/src/utils/taskUiState.test.mjs",
    "test:connection-health": "node server/scripts/connection-health-self-test.mjs",
    "test:error-guidance": "node server/scripts/error-guidance-self-test.mjs",
    "test:runtime-store": "node server/scripts/runtime-store-self-test.mjs",
    "e2e:smoke": "node server/scripts/run-e2e-smoke.mjs",
    "e2e:contract": "node server/scripts/run-api-contract-smoke.mjs",
    "check:release": "node server/scripts/pre-release-check.mjs",
    "acceptance:prod": "node server/scripts/production-acceptance.mjs",
    "acceptance:fault": "node server/scripts/fault-injection-acceptance.mjs",
    "audit:security": "node server/scripts/security-audit.mjs",
    "backup:rehearse": "node server/scripts/backup-restore-rehearsal.mjs",
    "check:onboarding": "node server/scripts/onboarding-path-check.mjs",
    "storage:sqlite:shadow": "node server/scripts/sqlite-shadow-migration.mjs",
    "verify:image": "node server/scripts/verify-image-release.mjs",
    "verify:image:fallback": "node server/scripts/image-pull-fallback.mjs",
    "stress:readiness": "node server/scripts/large-sync-readiness.mjs",
    "stress:e2e": "node server/scripts/large-sync-e2e-stress.mjs",
    "longrun:reliability": "node server/scripts/longrun-reliability.mjs",
    "realrun:reliability": "node server/scripts/realrun-reliability.mjs",
    "docker:build": "npm run build && docker build -t teable-sync .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
