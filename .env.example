# TeableSync 环境变量配置示例
# 复制这份文件为 .env，然后填入真实值（docker-compose 会自动读取 .env 文件）

# ============================================================
# 服务配置
# ============================================================
PORT=3101

# 前端 WebSocket 连接端口（可选）
VITE_WS_PORT=3101

# ============================================================
# 公开访问地址（Docker 部署时必填）
# Teable OAuth 回调地址使用此值
# ============================================================
SERVER_PUBLIC_URL=http://localhost:3101

# Teable 实例地址（自部署版）
TEABLE_OAUTH_HOST=http://localhost:3000

# 前端访问地址（OAuth 登录后重定向到此）
FRONTEND_BASE_URL=http://localhost:3101

# ============================================================
# 安全配置（生产环境必须修改）
# ============================================================
JWT_SECRET=change-me-to-a-random-secret-in-production

# ============================================================
# 数据库密码（Docker 部署时使用）
# ============================================================
# MSSQL / Azure SQL Edge
MSSQL_SA_PASSWORD=ChangeMe123!

# MySQL
MYSQL_ROOT_PASSWORD=ChangeMe123!

# PostgreSQL
POSTGRES_PASSWORD=ChangeMe123!

# Teable 自部署 PostgreSQL（可选）
TEABLE_DB_PASSWORD=ChangeMe123!
