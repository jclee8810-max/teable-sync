# ============================================================
# TeableSync 前端环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# --- 前端端口（开发服务器）---
VITE_FRONTEND_PORT=5173

# --- 后端 API 地址（代理配置）---
# 开发环境：http://localhost:3100
# 生产环境：通常与前端同域，留空即可
VITE_API_BASE_URL=http://localhost:3100

# --- 后端 API 主机和端口（WebSocket 代理）---
VITE_API_HOST=localhost
VITE_API_PORT=3100

# ============================================================
# 说明
# ============================================================
# 开发环境：前端 vite.config.js 会代理 /api 和 /ws 到后端
# 生产环境：前端构建后通常由 nginx 统一代理，无需这些变量
#
# 前端已支持局域网访问：
# - client/src/api.js 动态获取 API 地址（从 window.location.hostname）
# - client/vite.config.js 已配置 host: '0.0.0.0'
# ============================================================
