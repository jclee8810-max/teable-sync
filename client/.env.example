# Client development example.
# Production builds are normally served by the backend on PORT=3101.

VITE_FRONTEND_PORT=5173

# Backend API address for the Vite dev proxy.
VITE_API_BASE_URL=http://localhost:3101

# Backend WebSocket proxy target for Vite dev server.
VITE_API_HOST=localhost
VITE_API_PORT=3101
